<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewWardrobe"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/buttonAddItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add Item" />

    <Button
        android:id="@+id/buttonBuildOutfit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Make new outfit"/>

    <Button
        android:id="@+id/buttonAiSuggest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AI Outfit Suggestion" />

    <Button
        android:id="@+id/buttonViewOutfits"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="View outfits"/>

</LinearLayout>